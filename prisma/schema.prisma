// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  emailVerified Boolean       @default(false)
  name          String?
  image         String?       // better-auth default field
  avatarUrl     String?
  githubToken   String?
  githubLogin   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  accounts      Account[]
  analysisJobs  AnalysisJob[]
  reports       Report[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

model Account {
  id            String    @id @default(cuid())
  userId        String
  accountId     String
  providerId    String
  accessToken   String?
  refreshToken  String?
  idToken       String?
  expiresAt     DateTime?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model AnalysisJob {
  id          String    @id @default(cuid())
  userId      String
  repoUrl     String
  repoOwner   String
  repoName    String
  status      JobStatus @default(PENDING)
  progress    Int       @default(0)
  currentStep String?
  errorMsg    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  report      Report?

  @@index([userId])
  @@index([status])
  @@unique([userId, repoUrl, status])
}

model Report {
  id                String      @id @default(cuid())
  jobId             String      @unique
  userId            String
  repoUrl           String
  repoName          String
  repoOwner         String
  healthScore       Float
  grade             HealthGrade
  subScores         Json
  busFactor         Int
  riskAreas         Json
  contributors      Json
  heatmap           Json
  languages         Json
  topComplexFiles   Json
  teamHealthSignals Json        @default("[]")
  summary           String
  rawData           Json
  deletedAt         DateTime?
  createdAt         DateTime    @default(now())
  job               AnalysisJob @relation(fields: [jobId], references: [id])
  user              User        @relation(fields: [userId], references: [id])

  @@index([userId, deletedAt, createdAt(sort: Desc)])
  @@index([userId, deletedAt, healthScore(sort: Desc)])
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum HealthGrade {
  A_PLUS
  A
  B
  C
  D
  F
}